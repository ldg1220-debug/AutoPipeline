.env
node_modules/

# 로그 내용 제외 (디렉터리 구조는 .gitkeep으로 유지)
logs/*
!logs/.gitkeep

# 생성 결과물 제외 (디렉터리 구조는 .gitkeep으로 유지)
output/scripts/*
!output/scripts/.gitkeep
output/qa_reports/*
!output/qa_reports/.gitkeep

# 미디어 파일 제외 (용량), 디렉터리 구조는 .gitkeep으로 유지
output/media/*
!output/media/.gitkeep

# 키워드/블로그/분석 결과물
output/keywords/*
!output/keywords/.gitkeep
output/blog/*
!output/blog/.gitkeep
output/analytics/*
!output/analytics/.gitkeep

# SQLite DB (로컬 전용)
data/
