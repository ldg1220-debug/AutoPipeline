{
  "name": "autopipeline",
  "version": "1.0.0",
  "description": "Fully automated content pipeline: trend scraping → content creation → QA → publishing",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "agent:trend": "node src/agents/trend_scraper.js",
    "agent:content": "node src/agents/content_creator.js",
    "agent:qa": "node src/agents/qa_editor.js",
    "agent:publish": "node src/agents/auto_publisher.js",
    "agent:media": "node src/agents/media_generator.js",
    "dry-run": "cross-env DRY_RUN=true node src/app.js",
    "test-run": "cross-env DRY_RUN=true TEST_LIMIT=1 node src/app.js",
    "validate": "node scripts/validate-env.js",
    "status": "node scripts/check-status.js",
    "estimate": "node scripts/estimate-cost.js",
    "analyze": "node scripts/analyze-rejected.js",
    "analyze:grouper": "node scripts/analyze-grouper.js",
    "youtube:auth": "node scripts/get-youtube-token.js",
    "wp:publish": "node scripts/publish-wordpress.js",
    "affiliate:replace": "node scripts/replace-affiliate-links.js",
    "blog:keywords": "node src/agents/keyword_miner.js",
    "blog:content": "node src/agents/blog_content_enhancer.js",
    "blog:assets": "node src/agents/blog_asset_builder.js",
    "blog:monetize": "node src/agents/monetizer.js",
    "blog:publish": "node src/agents/blog_publisher.js",
    "blog:analytics": "node src/agents/blog_analytics.js",
    "blog:pipeline": "node scripts/run-blog-pipeline.js",
    "blog:login": "node scripts/tistory-login.js",
    "thumbnail:swap": "node scripts/swap-thumbnails.js",
    "thumbnail:swap:dry": "cross-env DRY_RUN=true node scripts/swap-thumbnails.js",
    "competitor:analyze": "node src/agents/competitor_analyzer.js",
    "youtube:auth:health": "node scripts/get-youtube-health-token.js",
    "director:strategy": "node src/agents/pipeline_director.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^12.10.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "winston": "^3.13.0",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
