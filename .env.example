GEMINI_API_KEY=

# 음성 합성
ELEVENLABS_API_KEY=

# YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# 티스토리 발행
TISTORY_ACCESS_TOKEN=
TISTORY_BLOG_NAME=ggoondaeng

# TikTok (선택)
TIKTOK_ACCESS_TOKEN=

# 영상 배경 스톡 (Pexels — 무료)
PEXELS_API_KEY=

# 영상 렌더링 (Shotstack)
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage
# stage = 샌드박스 무료(워터마크 포함) | production = 실제 과금
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# 텔레그램 알림 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 실행 설정
DRY_RUN=false
CRON_SCHEDULE=0 6 * * *
BLOG_CRON_SCHEDULE=0 8 * * *
MAX_RETRY=1

# ── Blog Pipeline (Part 1~6) ──────────────────────────────────
# Part 1: Keyword Miner
NAVER_CLIENT_ID=           # 네이버 데이터랩 API (선택 — 없으면 자동완성만 사용)
NAVER_CLIENT_SECRET=
KEYWORD_SEEDS=재테크,부동산,경기침체,금리,주식투자
KEYWORD_TOP_N=30

# Part 4: Monetizer
COUPANG_ACCESS_KEY=        # 쿠팡 파트너스 Open API
COUPANG_SECRET_KEY=
COUPANG_PARTNERS_ID=

# Part 5: Blog Publisher (Tistory — Playwright)
TISTORY_SESSION_COOKIE=    # 로그인 후 쿠키 (1회 수동 추출)

# Part 6: Analytics
GOOGLE_SC_CREDENTIALS=     # Search Console JSON 키 파일 경로

# Blog Settings
BLOG_POSTS_PER_DAY=2
BLOG_MIN_WORD_COUNT=1500

# Part 3: Asset Builder
# OPENAI_API_KEY 위에 이미 설정됨 (DALL-E 3 공용)
# PEXELS_API_KEY 위에 이미 설정됨 (본문 이미지 공용)

# Part 4: Monetizer
