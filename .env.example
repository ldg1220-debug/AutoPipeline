# LLM APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# xAI Grok API — 이미지 생성 (Aurora model: grok-2-image-1212)
# https://console.x.ai → API Keys 에서 발급
GROK_API_KEY=

# 음성 합성 — Naver ClovaVoice (한국어 원어민 품질, 월 10만 자 무료)
# Naver Cloud Platform → AI·Application Services → Clova Voice 에서 발급
NAVER_CLOVA_CLIENT_ID=
NAVER_CLOVA_CLIENT_SECRET=
# speaker: kyunghun(남성, 매읽남 캐릭터용) | nara_call(여성, 밝고 명료) | nara(여성, 일반)
# 매읽남 캐릭터 = 귀엽고 호기심 많은 남자 → kyunghun + pitch +4
CLOVA_VOICE_SPEAKER=kyunghun
# speed: -5~5 (0=기본, +1=약간 빠르고 활기찬 느낌)
CLOVA_VOICE_SPEED=1
# pitch: -5~5 (+4=약간 높고 귀여운 음조, 남자 고양이 느낌)
CLOVA_VOICE_PITCH=4
CLOVA_VOICE_VOLUME=0

# OpenAI TTS 보이스 (ClovaVoice 미설정 시 사용)
# 선택: alloy | echo | fable | onyx(남성 저음, 기본) | nova(여성) | shimmer(여성)
OPENAI_TTS_VOICE=onyx

# ElevenLabs (선택 — ClovaVoice 없을 때 참고용, 현재 미사용)
ELEVENLABS_API_KEY=

# YouTube Data API v3 — 기본 채널 (economy, finance, realestate, social, entertainment)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@매일읽어주는남자

# YouTube — 건강 채널 (별도 채널, 없으면 기본 채널로 발행)
YOUTUBE_HEALTH_CLIENT_ID=
YOUTUBE_HEALTH_CLIENT_SECRET=
YOUTUBE_HEALTH_REFRESH_TOKEN=
YOUTUBE_HEALTH_SERIES_NAME=매일읽어주는건강

# YouTube 카테고리별 재생목록 ID (YouTube Studio에서 미리 생성 후 PLxxxxxxxx 형식으로 입력)
YOUTUBE_PLAYLIST_ECONOMY=       # 경제·금융 재생목록
YOUTUBE_PLAYLIST_REALESTATE=    # 부동산 재생목록
YOUTUBE_PLAYLIST_HEALTH=        # 건강 재생목록
YOUTUBE_PLAYLIST_ENTERTAINMENT= # 연예·사회 재생목록

# 티스토리 발행
TISTORY_ACCESS_TOKEN=
TISTORY_BLOG_NAME=ggoondaeng

# TikTok (선택)
TIKTOK_ACCESS_TOKEN=

# 영상 배경 스톡 (Pexels — 무료)
PEXELS_API_KEY=

# 영상 렌더링 (Shotstack)
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage
# stage = 샌드박스 무료(워터마크 포함) | production = 실제 과금
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# 텔레그램 알림 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 실행 설정
DRY_RUN=false
# A 슬롯: 월·수·금·일 12:00 KST  |  B 슬롯: 화·목·토 14:00 KST
CRON_SCHEDULE=0 12 * * 1,3,5,0
CRON_SCHEDULE_B=0 14 * * 2,4,6
BLOG_CRON_SCHEDULE=0 13 * * 1,3,5,0
BLOG_CRON_SCHEDULE_B=0 15 * * 2,4,6
MAX_RETRY=1

# ── Blog Pipeline (Part 1~6) ──────────────────────────────────
# Part 1: Keyword Miner
NAVER_CLIENT_ID=           # 네이버 데이터랩 API (선택 — 없으면 자동완성만 사용)
NAVER_CLIENT_SECRET=
KEYWORD_SEEDS=재테크,부동산,경기침체,금리,주식투자,건강정보,다이어트,생활건강
KEYWORD_TOP_N=30

# Part 4: Monetizer
COUPANG_ACCESS_KEY=        # 쿠팡 파트너스 Open API
COUPANG_SECRET_KEY=
COUPANG_PARTNERS_ID=

# Part 5: Blog Publisher (Tistory — Playwright)
TISTORY_SESSION_COOKIE=    # 로그인 후 쿠키 (1회 수동 추출)

# Part 6: Analytics
GOOGLE_SC_CREDENTIALS=     # Search Console JSON 키 파일 경로

# Blog Settings
BLOG_POSTS_PER_DAY=2

# 경쟁 채널 분석 (competitor_analyzer)
COMPETITOR_MAX_CHANNELS=3   # 카테고리당 분석할 최대 채널 수
COMPETITOR_MAX_VIDEOS=10    # 채널당 최대 영상 수 (조회수 기준 상위)

# Topic Grouper — 같은 주제 키워드 자동 병합 모델
# OpenAI   : gpt-4o-mini (기본·저렴), gpt-4o (정확도 우선)
# Anthropic : claude-haiku-4-5 (빠름), claude-sonnet-4-6 (정확도 우선)
TOPIC_GROUPER_MODEL=gpt-4o-mini
# 검수 점수 미달 시 상위 모델로 에스컬레이션 (0~100, 기본 70)
TOPIC_GROUPER_THRESHOLD=70
BLOG_MIN_WORD_COUNT=1500

# Part 3: Asset Builder
# OPENAI_API_KEY 위에 이미 설정됨 (DALL-E 3 공용)
# PEXELS_API_KEY 위에 이미 설정됨 (본문 이미지 공용)

# DALL-E 이미지 캐시 — 유사 키워드 재사용 임계값 (0.0~1.0, 기본 0.88)
# 높을수록 같은 이미지를 덜 재사용 (정확), 낮을수록 더 많이 재사용 (절약)
IMAGE_CACHE_SIMILARITY=0.88

# 하루 최대 롱폼 영상 수 (핫이슈 있을 때만 2로 올릴 것)
DAILY_VIDEOS=1

# 쇼츠 업로드 여부 (true=업로드, false=건너뜀)
PUBLISH_SHORTS=false

# YouTube 업로드 여부 (false=건너뜀 — 영상 제작+블로그만 하고 나중에 업로드할 때)
# 나중에 업로드: node scripts/rerun-media-upload.js --upload-only
YOUTUBE_UPLOAD=true

# 썸네일 A/B 테스트
# Variant A(발행 시)→B(N일 후 자동 교체). npm run thumbnail:swap 으로 실행
THUMBNAIL_SWAP_DAYS=7

# Part 4: Monetizer
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX
ADSENSE_SLOT_ID=0000000000
